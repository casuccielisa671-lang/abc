# ============================================================
# 职业能力大数据服务平台 — 生产环境变量配置
# 复制为 .env 并修改实际值
# ============================================================

# 数据库密码（必改）
DB_PASSWORD=Occupation@2026!

# Redis 密码（必改）
REDIS_PASSWORD=Redis@2026!

# JWT 签名密钥（必改，建议 32 位以上随机字符串）
JWT_SECRET=change-me-to-a-random-string-in-production

# Spring Profile：生产环境建议 prod；本地开发可不填，默认 dev,local
SPRING_PROFILES_ACTIVE=prod

# AI 能力（可选，需要 DeepSeek API Key）
AI_ENABLED=false
AI_API_KEY=
