# ============================================================
# 职业能力大数据服务平台 — 前端 Nginx 镜像
# 构建阶段自动安装依赖并生成 dist，避免云服务器依赖本地构建产物。
# ============================================================

FROM node:20-alpine AS builder

WORKDIR /web
COPY occupation-web-ui/package*.json ./
RUN npm ci
COPY occupation-web-ui ./
RUN npm run build

FROM nginx:1.24-alpine

COPY --from=builder /web/dist /usr/share/nginx/html
